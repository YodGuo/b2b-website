---

<footer class="bg-secondary-900 text-secondary-300">
  <div class="container-custom py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center space-x-2 mb-4">
          {companyLogo ? (
            <img src={companyLogo} alt={companyName} class="h-8 w-auto brightness-0 invert" />
          ) : (
            <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
              <span class="text-white font-bold text-sm">{companyName.charAt(0)}</span>
            </div>
          )}
          <span class="font-display font-bold text-lg text-white">{companyName}</span>
        </div>
        {companySlogan && (
          <p class="text-sm text-secondary-400 mb-4">{companySlogan}</p>
        )}
        {socialLinks.length > 0 && (
          <div class="flex space-x-3">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-secondary-400 hover:text-white transition-colors"
                aria-label={link.platform}
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" set:html={socialIcons[link.platform] || socialIcons.other || ''} />
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Products -->
      <div>
        <h4 class="font-semibold text-white mb-4">Products</h4>
        <ul class="space-y-2">
          <li><a href="/products" class="text-sm hover:text-white transition-colors">All Products</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold text-white mb-4">Company</h4>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm hover:text-white transition-colors">About Us</a></li>
          <li><a href="/news" class="text-sm hover:text-white transition-colors">News</a></li>
          <li><a href="/contact" class="text-sm hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h4 class="font-semibold text-white mb-4">Support</h4>
        <ul class="space-y-2">
          <li><a href="/faq" class="text-sm hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/privacy" class="text-sm hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm hover:text-white transition-colors">Terms & Conditions</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-secondary-800 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-sm text-secondary-400">
        &copy; {currentYear} {copyrightText}. All rights reserved.
      </p>
      <div class="flex items-center space-x-4 mt-2 md:mt-0">
        {footerLinks.map((link) => (
          <a href={link.url} class="text-sm text-secondary-400 hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
