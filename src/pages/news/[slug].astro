---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import CommentList from '../../components/comments/CommentList.astro';
import { CommentForm } from '../../components/comments/CommentForm.tsx';
import { getCollection, render } from 'astro:content';
import { getCommentsWithReplies, getCommentCount } from '../../lib/db/comments';
import { withCache } from '../../lib/cache';
import { getSettings } from '../../lib/settings';

export async function getStaticPaths() {
  const newsItems = await getCollection('news', ({ data }) => data.published);
  return newsItems.map((item) => ({
    params: { slug: item.id },
    props: { newsItem: item },
  }));
}

export const prerender = false

const settings = await getSettings();
const { newsItem } = Astro.props;
const { Content } = await render(newsItem);

let comments: Awaited<ReturnType<typeof getCommentsWithReplies>> = [];
let commentCount = 0;

try {
  const { locals } = Astro;
  if (locals.runtime?.env?.DB && locals.runtime?.env?.SESSION) {
    const newsId = parseInt(newsItem.id.split('-').pop() || '0');
    const kv = locals.runtime.env.SESSION;

    // 评论列表使用 KV 缓存（5 分钟 TTL），减少 D1 查询
    comments = await withCache(
      kv,
      `comments:news:${newsId}`,
      () => getCommentsWithReplies(locals.runtime!.env!.DB, newsId),
      { ttl: 300, namespace: 'comments' }
    );

    // 评论计数使用 KV 缓存
    commentCount = await withCache(
      kv,
      `comment-count:news:${newsId}`,
      () => getCommentCount(locals.runtime!.env!.DB, undefined, 'approved'),
      { ttl: 300, namespace: 'comments' }
    );
  }
} catch (error) {
  console.error('Failed to fetch comments:', error);
}

// JSON-LD 结构化数据
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://yourdomain.com';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": newsItem.data.title,
  "description": newsItem.data.description,
  "author": {
    "@type": "Person",
    "name": newsItem.data.author,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Company",
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/logo.png`,
    },
  },
  "datePublished": newsItem.data.publishDate.toISOString(),
  "image": newsItem.data.coverImage || '',
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/news/${newsItem.id}`,
  },
};
---

<BaseLayout title={newsItem.data.title} description={newsItem.data.description} settings={settings}>
  <Header slot="header" />
  <Footer slot="footer" />

  <!-- JSON-LD 结构化数据 -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article>
    <!-- Article Header -->
    <header class="bg-gradient-to-br from-primary-50 to-white py-12 md:py-16">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto">
          <a href="/news" class="inline-flex items-center text-primary-600 hover:text-primary-700 mb-6">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            返回新闻列表
          </a>

          <div class="flex items-center gap-3 mb-4">
            <span class="px-3 py-1 bg-primary-100 text-primary-700 text-sm font-medium rounded-full">
              {newsItem.data.category}
            </span>
            {newsItem.data.tags.slice(0, 3).map((tag) => (
              <span class="px-3 py-1 bg-secondary-100 text-secondary-600 text-sm rounded-full">
                {tag}
              </span>
            ))}
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-secondary-900 mb-4">
            {newsItem.data.title}
          </h1>

          <div class="flex items-center space-x-4 text-secondary-500">
            <span class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              {newsItem.data.author}
            </span>
            <span class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {newsItem.data.publishDate.toLocaleDateString('zh-CN')}
            </span>
            <span class="flex items-center">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
              {commentCount} 评论
            </span>
          </div>
        </div>
      </div>
    </header>

    <!-- Cover Image -->
    {newsItem.data.coverImage && (
      <div class="container-custom py-8">
        <div class="max-w-4xl mx-auto">
          <img
            src={newsItem.data.coverImage}
            alt={newsItem.data.title}
            class="w-full rounded-xl shadow-lg"
          />
        </div>
      </div>
    )}

    <!-- Article Content -->
    <div class="container-custom py-8">
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-lg prose-secondary max-w-none
          prose-headings:font-display prose-headings:font-bold
          prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-3
          prose-p:text-secondary-700 prose-p:leading-relaxed
          prose-li:text-secondary-700
          prose-strong:text-secondary-900
          prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline
          prose-blockquote:border-primary-400 prose-blockquote:bg-primary-50
        ">
          <Content />
        </div>
      </div>
    </div>
  </article>

  <!-- Comments Section -->
  <section class="section bg-secondary-50">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-secondary-900 mb-8">
          评论 ({commentCount})
        </h2>

        <!-- Comment Form -->
        <div class="bg-white rounded-xl p-6 mb-8 shadow-sm">
          <h3 class="text-lg font-semibold text-secondary-900 mb-4">发表评论</h3>
          <CommentForm client:idle newsId={1} />
        </div>

        <!-- Comments List -->
        <CommentList comments={comments} newsId={1} />
      </div>
    </div>
  </section>
</BaseLayout>
