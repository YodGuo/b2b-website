---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { getPendingComments, updateCommentStatus, getCommentCount } from '../../lib/db/comments';
import { getNewsById } from '../../lib/db/news';
import { getInquiries, updateInquiryStatus, getInquiryCount } from '../../lib/db/inquiries';
import { isAuthenticated, createUnauthorizedResponse, getServerSession } from '../../lib/auth';
import { requireCmsHost } from '../../lib/routing';
import { deleteCache } from '../../lib/cache';

export const prerender = false

// ========== 域名守卫：仅允许 cms.xxxx.com 访问 ==========
const cmsGuard = requireCmsHost(Astro.request);
if (cmsGuard) return cmsGuard;

// ========== 认证检查 ==========
const db = Astro.locals.runtime?.env?.DB;
if (db) {
  const authenticated = await isAuthenticated(Astro.request, db);
  if (!authenticated) {
    return createUnauthorizedResponse();
  }
}

// 获取当前用户信息
const session = db ? await getServerSession(Astro.request, db) : null;

// ========== 处理登出 ==========
const url = new URL(Astro.request.url);
if (url.searchParams.get('action') === 'logout') {
  // Better Auth sign-out: 通过客户端 JS 调用 /api/auth/sign-out
  // 这里返回一个带 JS 的页面来执行注销
  return new Response(`<!DOCTYPE html><html><head><script>
    fetch('/api/auth/sign-out', { method: 'POST' }).then(() => window.location.href = '/admin/login');
  </script></head><body>Signing out...</body></html>`, {
    headers: { 'Content-Type': 'text/html' },
  });
}

// ========== 获取数据 ==========
let pendingComments: Awaited<ReturnType<typeof getPendingComments>> = [];
let pendingInquiries: Awaited<ReturnType<typeof getInquiries>> = [];
let stats = { pendingComments: 0, pendingInquiries: 0 };

try {
  if (locals.runtime?.env?.DB) {
    pendingComments = await getPendingComments(locals.runtime.env.DB, 20, 0);
    pendingInquiries = await getInquiries(locals.runtime.env.DB, { status: 'pending', limit: 20 });
    stats.pendingComments = await getCommentCount(locals.runtime.env.DB, undefined, 'pending');
    stats.pendingInquiries = await getInquiryCount(locals.runtime.env.DB, 'pending');
  }
} catch (error) {
  console.error('Failed to fetch admin data:', error);
}

// ========== 处理表单操作 ==========
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action') as string;
  const id = parseInt(formData.get('id') as string);
  const type = formData.get('type') as string;

  if (locals.runtime?.env?.DB && id) {
    if (type === 'comment') {
      await updateCommentStatus(locals.runtime.env.DB, id, action as 'approved' | 'rejected');
      // 审核评论后清除对应文章的评论缓存
      if (locals.runtime?.env?.SESSION) {
        await deleteCache(locals.runtime.env.SESSION, `comments:news:${id}`, { namespace: 'comments' });
        await deleteCache(locals.runtime.env.SESSION, `comment-count:news:${id}`, { namespace: 'comments' });
      }
    } else if (type === 'inquiry') {
      await updateInquiryStatus(locals.runtime.env.DB, id, action as 'contacted' | 'closed');
    }
    return Astro.redirect('/admin');
  }
}
---

<BaseLayout title="管理后台">
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="section bg-secondary-50 min-h-screen">
    <div class="container-custom">
      <!-- 头部与登出 -->
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-secondary-900">管理后台</h1>
        <div class="flex items-center space-x-4">
          <a href="/keystatic" class="btn-secondary text-sm" target="_blank">
            📝 内容管理
          </a>
          <a href="/admin?action=logout" class="text-sm text-secondary-500 hover:text-red-600 transition-colors">
            退出登录
          </a>
        </div>
      </div>

      <!-- 统计数据 -->
      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="card p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-secondary-500">待审核评论</p>
              <p class="text-3xl font-bold text-secondary-900">{stats.pendingComments}</p>
            </div>
            <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
          </div>
        </div>

        <div class="card p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-secondary-500">待处理询价</p>
              <p class="text-3xl font-bold text-secondary-900">{stats.pendingInquiries}</p>
            </div>
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- 待处理询价 -->
      {pendingInquiries.length > 0 && (
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-secondary-900 mb-4">待处理询价</h2>
          <div class="space-y-4">
            {pendingInquiries.map((inquiry) => (
              <div class="card p-6">
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="font-semibold text-secondary-900">{inquiry.company_name}</span>
                      <span class="text-secondary-400">|</span>
                      <span class="text-secondary-600">{inquiry.contact_name}</span>
                    </div>
                    <div class="text-sm text-secondary-500 space-y-1">
                      <p>邮箱：<a href={`mailto:${inquiry.email}`} class="text-primary-600 hover:underline">{inquiry.email}</a></p>
                      {inquiry.phone && <p>电话：{inquiry.phone}</p>}
                      {inquiry.country && <p>国家：{inquiry.country}</p>}
                      {inquiry.product_interest && <p>产品：{inquiry.product_interest}</p>}
                      {inquiry.quantity && <p>数量：{inquiry.quantity}</p>}
                    </div>
                    <p class="mt-3 text-secondary-700">{inquiry.message}</p>
                    <p class="text-xs text-secondary-400 mt-2">
                      {new Date(inquiry.created_at).toLocaleString('zh-CN')}
                    </p>
                  </div>
                  <form method="POST" class="flex gap-2">
                    <input type="hidden" name="type" value="inquiry" />
                    <input type="hidden" name="id" value={inquiry.id} />
                    <button type="submit" name="action" value="contacted" class="btn-primary text-sm">
                      已联系
                    </button>
                    <button type="submit" name="action" value="closed" class="btn-secondary text-sm">
                      关闭
                    </button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- 待审核评论 -->
      {pendingComments.length > 0 && (
        <div>
          <h2 class="text-xl font-semibold text-secondary-900 mb-4">待审核评论</h2>
          <div class="space-y-4">
            {pendingComments.map(async (comment) => {
              const newsItem = comment.news_id ? await getNewsById(Astro.locals.runtime?.env?.DB!, comment.news_id) : null;
              return (
                <div class="card p-6">
                  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="font-semibold text-secondary-900">{comment.author_name}</span>
                        {comment.author_email && (
                          <>
                            <span class="text-secondary-400">|</span>
                            <span class="text-secondary-600 text-sm">{comment.author_email}</span>
                          </>
                        )}
                      </div>
                      {newsItem && (
                        <p class="text-sm text-primary-600 mb-2">
                          文章：<a href={`/news/${newsItem.slug}`} class="hover:underline">{newsItem.title}</a>
                        </p>
                      )}
                      <p class="text-secondary-700">{comment.content}</p>
                      <p class="text-xs text-secondary-400 mt-2">
                        {new Date(comment.created_at).toLocaleString('zh-CN')}
                        {comment.ip_address && ` · IP: ${comment.ip_address}`}
                      </p>
                    </div>
                    <form method="POST" class="flex gap-2">
                      <input type="hidden" name="type" value="comment" />
                      <input type="hidden" name="id" value={comment.id} />
                      <button type="submit" name="action" value="approved" class="btn-primary text-sm">
                        通过
                      </button>
                      <button type="submit" name="action" value="rejected" class="btn-secondary text-sm">
                        拒绝
                      </button>
                    </form>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {pendingComments.length === 0 && pendingInquiries.length === 0 && (
        <div class="text-center py-12">
          <svg class="w-16 h-16 mx-auto text-secondary-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-secondary-500">暂无待处理事项</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
