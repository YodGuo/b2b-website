---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="text-center max-w-lg mx-auto px-4">
      <!-- 404 Illustration -->
      <div class="mb-8">
        <h1 class="text-8xl font-display font-bold text-primary-600">404</h1>
        <div class="w-24 h-1 bg-primary-600 mx-auto mt-4 rounded-full"></div>
      </div>

      <h2 class="text-2xl font-bold text-secondary-900 mb-4">Page Not Found</h2>
      <p class="text-secondary-600 mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
        Let's get you back on track.
      </p>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Back to Home
        </a>
        <a
          href="/contact"
          class="inline-flex items-center px-6 py-3 border-2 border-secondary-200 text-secondary-700 font-semibold rounded-lg hover:border-primary-600 hover:text-primary-600 transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Contact Support
        </a>
      </div>

      <!-- Helpful Links -->
      <div class="mt-12 pt-8 border-t border-secondary-100">
        <p class="text-sm text-secondary-500 mb-4">Popular pages you might be looking for:</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/products" class="text-sm px-4 py-2 bg-secondary-50 text-secondary-600 rounded-lg hover:bg-primary-50 hover:text-primary-600 transition-colors">
            Products
          </a>
          <a href="/news" class="text-sm px-4 py-2 bg-secondary-50 text-secondary-600 rounded-lg hover:bg-primary-50 hover:text-primary-600 transition-colors">
            News
          </a>
          <a href="/about" class="text-sm px-4 py-2 bg-secondary-50 text-secondary-600 rounded-lg hover:bg-primary-50 hover:text-primary-600 transition-colors">
            About Us
          </a>
          <a href="/faq" class="text-sm px-4 py-2 bg-secondary-50 text-secondary-600 rounded-lg hover:bg-primary-50 hover:text-primary-600 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
