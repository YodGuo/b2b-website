---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { InquiryForm } from '../components/forms/InquiryForm';
import { getSettings } from '../lib/settings';

const settings = await getSettings();

const productInterest = Astro.url.searchParams.get('product') || undefined;
---

<BaseLayout title="Contact Us" description="Contact us for product inquiries and professional services" settings={settings}>
  <Header slot="header" />
  <Footer slot="footer" />

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-primary-50 to-white py-12 md:py-20">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-secondary-900 mb-4">
          Contact Us
        </h1>
        <p class="text-lg text-secondary-600">
          Feel free to inquire about our products and services. We will respond within 24 hours.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section">
    <div class="container-custom">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-1">
          <div class="space-y-8">
            <!-- Email -->
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-secondary-900">Email</h3>
                <a href="mailto:sales@yourcompany.com" class="text-primary-600 hover:underline">
                  sales@yourcompany.com
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-secondary-900">Phone</h3>
                <p class="text-secondary-600">+86 400-XXX-XXXX</p>
                <p class="text-sm text-secondary-400">Monday - Friday 9:00-18:00</p>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-secondary-900">Address</h3>
                <p class="text-secondary-600">
                  Shenzhen, Guangdong Province, China<br />
                  XX Road, XX District
                </p>
              </div>
            </div>

            <!-- Working Hours -->
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-secondary-900">Business Hours</h3>
                <p class="text-secondary-600">Monday - Friday: 9:00 - 18:00</p>
                <p class="text-secondary-600">Saturday: 9:00 - 12:00</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Inquiry Form -->
        <div class="lg:col-span-2">
          <div class="card p-6 md:p-8">
            <h2 class="text-2xl font-bold text-secondary-900 mb-6">Online Inquiry</h2>
            <InquiryForm client:load productInterest={productInterest} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section (Optional) -->
  <section class="section pt-0">
    <div class="container-custom">
      <div class="card overflow-hidden">
        <div class="bg-secondary-100 h-80 flex items-center justify-center">
          <p class="text-secondary-500">Map Location (Google Maps or Baidu Maps can be embedded here)</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
